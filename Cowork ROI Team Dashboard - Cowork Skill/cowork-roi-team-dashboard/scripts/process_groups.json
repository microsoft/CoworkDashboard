{
  "_note": "Canonical business-process GROUPING. Collapses the long tail of process labels (APQC fallback labels, per-user registry-minted names, and process_overrides names) into ONE short, stable, industry-relevant set so the 'Work by business process' table isn't a long list. Applied as the final normalization of `process` in classify.py (group_process). Pillars and Jobs-to-be-done stay granular — only the process LABEL is grouped. SHARED CONTRACT: this file is duplicated byte-for-byte in cowork-roi-member and cowork-roi-report; the aggregated ('Dashboard') skill reuses cowork-roi-report's copy. Keep the copies identical or team aggregation drifts.",
  "groups": [
    "Business Value & ROI Analytics",
    "Skill Development",
    "Sales & Customer Engagement",
    "Team Enablement & Communications",
    "Strategy & Planning",
    "Technology & Engineering",
    "Service Delivery & Operations",
    "Risk, Compliance & Governance",
    "People & Talent Management",
    "General Productivity"
  ],
  "apqc_to_group": {
    "Strategy & Planning": "Strategy & Planning",
    "Product & Service Development": "Strategy & Planning",
    "Sales & Customer Engagement": "Sales & Customer Engagement",
    "Customer Success & Support": "Sales & Customer Engagement",
    "Service Delivery & Operations": "Service Delivery & Operations",
    "Procurement & Vendor Management": "Service Delivery & Operations",
    "People & Talent Management": "People & Talent Management",
    "Technology & Engineering": "Technology & Engineering",
    "Finance & Business Value": "Business Value & ROI Analytics",
    "Analytics, Insights & Reporting": "Business Value & ROI Analytics",
    "Risk, Compliance & Governance": "Risk, Compliance & Governance",
    "Stakeholder & External Relations": "Team Enablement & Communications",
    "Capability & Skill Development": "Skill Development"
  },
  "_keyword_rules_note": "For free-form registry-minted / override process names that are NOT one of the fixed APQC labels. Ordered specific -> general; FIRST rule with any keyword found as a case-insensitive substring wins. Order matters (e.g. 'Team Performance Reporting' must hit Team Enablement before Business Value's 'reporting'). A label matching no rule keeps its own name (fold it into a group later by renaming it in the per-user registry).",
  "keyword_rules": [
    {"group": "Skill Development", "any": ["skill", "automation development", "capability", "playbook", "methodology", "tool building", "skill packaging", "change management", "learning", "training material"]},
    {"group": "Team Enablement & Communications", "any": ["newsletter", "communication", "stakeholder", "enablement content", "team enablement", "team performance", "announcement", "memo", "external relation", "briefing", "messaging", "recap", "digest"]},
    {"group": "Business Value & ROI Analytics", "any": ["roi", "value quantification", "business value", "value assessment", "value story", "analytics", "insight", "reporting", "kpi", "dashboard", "benchmark", "finance", "financial", "cost analysis", "cost reduction", "impact report", "measurement"]},
    {"group": "Sales & Customer Engagement", "any": ["sales", "customer", "account", "pitch", "proposal", "deal", "rfp", "rfi", "pursuit", "opportunity", "discovery", "renewal", "adoption", "demo"]},
    {"group": "People & Talent Management", "any": ["talent", "hiring", "recruit", "performance review", "connect review", "year end review", "headcount", "org design", "compensation", "promotion", "workforce", "people management"]},
    {"group": "Risk, Compliance & Governance", "any": ["risk", "compliance", "governance", "audit", "regulatory", "policy", "privacy", "security control", "controls"]},
    {"group": "Technology & Engineering", "any": ["engineering", "software", "coding", " code", "api", "infrastructure", "pipeline", "debug", "refactor", "deployment", "integration", "architecture", "database"]},
    {"group": "Service Delivery & Operations", "any": ["operations", "delivery", "fulfillment", "implementation", "procurement", "vendor", "sourcing", "logistics", "runbook", "support ticket", "incident"]},
    {"group": "Strategy & Planning", "any": ["strategy", "planning", "roadmap", "product development", "go-to-market", "gtm", "okr", "objectives", "business case", "prioritization"]}
  ],
  "default": "General Productivity"
}
